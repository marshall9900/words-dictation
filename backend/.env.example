# Words Dictation v2 - Backend Environment Variables

# ── Server ──────────────────────────────────────
NODE_ENV=development
PORT=3001
JWT_SECRET=your_jwt_secret_change_in_production
JWT_EXPIRES_IN=7d

# ── Database ────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=words_dictation_v2
DB_USER=root
DB_PASSWORD=your_db_password

# ── Redis ────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── MiniMax AI (Phase 1 - 图片+配音) ────────────
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_GROUP_ID=your_minimax_group_id
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# MiniMax Image Generation
MINIMAX_IMAGE_MODEL=image-01
MINIMAX_IMAGE_WIDTH=1024
MINIMAX_IMAGE_HEIGHT=1024

# MiniMax TTS
MINIMAX_TTS_MODEL=speech-02
MINIMAX_TTS_VOICE=female-tianmei-jingpin
MINIMAX_TTS_SPEED=0.9

# ── Azure TTS (Phase 2 - 单词朗读) ──────────────
AZURE_TTS_KEY=
AZURE_TTS_REGION=eastus

# ── OpenAI Whisper (Phase 2 - ASR) ──────────────
OPENAI_API_KEY=

# ── 科大讯飞发音评测 (Phase 2) ───────────────────
XFYUN_APP_ID=
XFYUN_API_KEY=
XFYUN_API_SECRET=

# ── 腾讯云 COS ───────────────────────────────────
TENCENT_SECRET_ID=your_tencent_secret_id
TENCENT_SECRET_KEY=your_tencent_secret_key
COS_BUCKET=words-dictation-1234567890
COS_REGION=ap-guangzhou
CDN_BASE_URL=https://cdn.wordsdict.cn

# ── 腾讯云 OCR (Phase 2) ─────────────────────────
TENCENT_OCR_REGION=ap-guangzhou

# ── Content Moderation ──────────────────────────
TENCENT_CIR_REGION=ap-guangzhou
CONTENT_AUDIT_ENABLED=false

# ── Rate Limiting ────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ── Queue ────────────────────────────────────────
PICTUREBOOK_QUEUE_CONCURRENCY=3
PICTUREBOOK_QUEUE_MAX_RETRIES=3

# ── Cache ────────────────────────────────────────
PICTUREBOOK_CACHE_TTL=86400
