#===============================================
# Words Dictation v2 - 腾讯云部署环境变量配置
# 请复制此文件为 .env 并填写真实配置
#===============================================

# ── Server ──────────────────────────────────────
NODE_ENV=production
PORT=3001
JWT_SECRET=CHANGE_ME_JWT_SECRET_32_CHARS_MIN
JWT_EXPIRES_IN=7d

# ── Database (MySQL 8.0) ───────────────────────
DB_HOST=mysql
DB_PORT=3306
DB_NAME=words_dictation_v2
DB_USER=words_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Redis ────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── MiniMax AI (图片生成 + 配音) ───────────────
# 可选：已集成 MiniMax API 用于绘本图片和配音
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_minimax_group_id_here
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# MiniMax 图片生成模型
MINIMAX_IMAGE_MODEL=image-01
MINIMAX_IMAGE_WIDTH=1024
MINIMAX_IMAGE_HEIGHT=1024

# MiniMax TTS 语音合成
MINIMAX_TTS_MODEL=speech-02
MINIMAX_TTS_VOICE=female-tianmei-jingpin
MINIMAX_TTS_SPEED=0.9

# ── Azure TTS (单词朗读 - Phase 2) ──────────────
AZURE_TTS_KEY=
AZURE_TTS_REGION=eastus

# ── OpenAI Whisper (语音识别 - Phase 2) ────────
OPENAI_API_KEY=

# ── 科大讯飞发音评测 (Phase 2) ───────────────────
XFYUN_APP_ID=
XFYUN_API_KEY=
XFYUN_API_SECRET=

# ── 腾讯云 COS (对象存储) ───────────────────────
# 用于存储生成的绘本音频和图片
TENCENT_SECRET_ID=your_tencent_secret_id_here
TENCENT_SECRET_KEY=your_tencent_secret_key_here
COS_BUCKET=words-dictation-xxxxxxxx
COS_REGION=ap-guangzhou
CDN_BASE_URL=https://cdn.your-domain.com

# ── 腾讯云 OCR (Phase 2) ─────────────────────────
TENCENT_OCR_REGION=ap-guangzhou

# ── 腾讯云内容审核 CIR ───────────────────────────
TENCENT_CIR_REGION=ap-guangzhou
CONTENT_AUDIT_ENABLED=false

# ── Rate Limiting ────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ── Queue (后台任务队列) ─────────────────────────
PICTUREBOOK_QUEUE_CONCURRENCY=3
PICTUREBOOK_QUEUE_MAX_RETRIES=3

# ── Cache ────────────────────────────────────────
PICTUREBOOK_CACHE_TTL=86400

# ── 上传文件配置 ─────────────────────────────────
UPLOAD_MAX_SIZE=50
ALLOWED_EXTENSIONS=jpg,jpeg,png,wav,mp3,m4a
